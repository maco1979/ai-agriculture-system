{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "buildAptPackages": ["git", "curl"],
  "packages": {
    "python": "3.13"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install -r requirements.txt"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["..."]
    }
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT"
  }
}
