# ============================================================
# AI农业决策系统 - 环境变量配置
# 使用方法：复制此文件为 .env，然后填入你的配置
#   cp .env.example .env
# ============================================================

# ────────────────────────────────────────────────────────────
# 🤖 AI 模型配置（选一个填入即可，系统自动识别）
# ────────────────────────────────────────────────────────────

# ✅ 推荐：DeepSeek（价格极低，效果好，国内访问稳定）
# 注册并获取 API Key：https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（需要可访问 api.openai.com）
# 注册：https://platform.openai.com
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1   # 如需代理可修改此地址

# 腾讯混元（国内用户推荐）
# 开通：https://console.cloud.tencent.com/hunyuan
# HUNYUAN_SECRET_ID=
# HUNYUAN_API_KEY=
# HUNYUAN_MODEL=hunyuan-standard

# 阿里通义千问
# 开通：https://dashscope.aliyun.com
# QWEN_API_KEY=
# QWEN_MODEL=qwen-plus

# 智谱 GLM（glm-4-flash 免费）
# 注册：https://open.bigmodel.cn
# ZHIPU_API_KEY=
# ZHIPU_MODEL=glm-4-flash


# ────────────────────────────────────────────────────────────
# 🔧 后端服务配置
# ────────────────────────────────────────────────────────────

# 应用运行端口（默认 8000）
PORT=8000

# 调试模式（开发时设为 true，生产环境保持 false）
DEBUG=false

# 数据库（默认 SQLite，无需额外安装）
DATABASE_URL=sqlite:///./data/app.db

# Redis（默认连接 docker-compose 内的 redis）
REDIS_URL=redis://redis:6379/0

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO


# ────────────────────────────────────────────────────────────
# 🌐 前端配置
# ────────────────────────────────────────────────────────────

# 后端 API 地址（本地运行时无需修改）
VITE_API_URL=http://localhost:8000

# 应用名称（显示在页面标题）
VITE_APP_NAME=AI农业决策系统


# ────────────────────────────────────────────────────────────
# 📌 说明
# ────────────────────────────────────────────────────────────
# 1. 只需填入一个 AI 模型的 API Key，系统自动工作
# 2. DeepSeek 每百万 token 约 1 元人民币，非常经济
# 3. .env 文件已加入 .gitignore，不会被提交到 GitHub
# 4. 如不填写 API Key，系统仍可启动，AI 功能会提示配置
