# ============================================
# AI农业决策系统 - 环境变量模板
# ============================================
# 复制此文件为 .env.production 并填入实际值

# 数据库配置 (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# Supabase密钥
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=[YOUR_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]

# 应用配置
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=8000

# JWT配置
JWT_SECRET=[YOUR_JWT_SECRET]
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# 前端API配置
VITE_API_BASE_URL=https://[YOUR_BACKEND_URL].up.railway.app

# 存储配置
STORAGE_BUCKET=agriculture-data
STORAGE_REGION=us-east-1

# 邮件配置（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[YOUR_EMAIL]
SMTP_PASSWORD=[YOUR_APP_PASSWORD]

# ============================================
# 如何获取这些值：
# ============================================
# 1. Supabase项目：
#    - 访问: https://supabase.com/dashboard
#    - 创建项目后获取: URL, anon key, service role key
#    - 数据库密码: 项目设置中设置
#
# 2. JWT密钥生成：
#    - 运行: openssl rand -base64 32
#    - 或: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 3. Railway后端URL：
#    - 部署后从Railway控制台获取
# ============================================