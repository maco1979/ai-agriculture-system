# ============================================================
# AI农业决策系统 - 环境变量模板
# 复制此文件为 .env 并填入真实值，不要提交 .env 到 Git！
# ============================================================

# ── 基础配置 ──────────────────────────────────
ENVIRONMENT=production
PORT=8000
DEBUG=false

# ── 数据库 ────────────────────────────────────
# PostgreSQL 连接字符串
# 格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ai_agriculture

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 安全配置 ──────────────────────────────────
# JWT 签名密钥（请用随机强密码，至少32位）
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_very_long_and_random_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── 跨域配置 ──────────────────────────────────
# 生产环境改为你的真实域名，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ── 阿里云配置（用于镜像仓库）──────────────────
# 在 GitHub Actions Secrets 中设置，不需要写在这里
# ALIYUN_REGISTRY_USERNAME=
# ALIYUN_REGISTRY_PASSWORD=

# ── 可选：微信小程序 ───────────────────────────
# 不要提交真实 AppID，使用 project.config.json.example
# WECHAT_APP_ID=YOUR_WECHAT_APPID_HERE
# WECHAT_APP_SECRET=YOUR_WECHAT_APPSECRET_HERE

# ── 可选：通知 Webhook ────────────────────────
# 钉钉机器人 Webhook
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
